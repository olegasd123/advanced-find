{
  "SearchSchema": {
    "Entities": [
      {
        "LogicalName": "invoice",
        "RelationPaths": [
          {
            "Id": "invoice-created-by",
            "Steps": [
              {
                "EntityName": "systemuser",
                "FromAttribute": "createdby",
                "ToAttribute": "systemuserid"
              }
            ]
          },
          {
            "Id": "invoice-to-detail",
            "Steps": [
              {
                "EntityName": "invoicedetail",
                "FromAttribute": "invoiceid",
                "ToAttribute": "invoiceid"
              }
            ]
          },
          {
            "Id": "invoice-to-product",
            "Steps": [
              {
                "EntityName": "invoicedetail",
                "FromAttribute": "invoiceid",
                "ToAttribute": "invoiceid"
              },
              {
                "EntityName": "product",
                "FromAttribute": "productid",
                "ToAttribute": "productid"
              }
            ]
          }
        ],
        "FilterCategories": [
          {
            "Id": "general",
            "DisplayName": "General"
          },
          {
            "Id": "misc",
            "DisplayName": "Misc"
          }
        ],
        "FilterUniqueOptionsOnly": true,
        "FilterOptions": [
          {
            "CategoryId": "general",
            "AttributeName": "invoicenumber",
            "DisplayName": "Invoice number",
            "Default": {
              "IsShown": true,
              "Condition": "ne",
              "Values": ["1"],
              "IsAttributeDisabled": true,
              "IsDisabled": false,
              "CannotBeRemoved": true
            },
            "Groupable": false,
            "Selection": {
              "Multiple": true,
              "MinItems": 1,
              "MaxItems": 2
            }
          },
          {
            "CategoryId": "general",
            "AttributeName": "name",
            "Default": {
              "IsShown": true,
              "Values": ["invoice name 1"]
            }
          },
          {
            "CategoryId": "general",
            "AttributeName": "createdby",
            "Default": {
              "IsShown": true
            },
            "Lookup": {
              "AttributeNames": ["lastname"]
            }
          },
          {
            "CategoryId": "general",
            "AttributeName": "modifiedby",
            "Default": {
              "IsShown": true
            },
            "Selection": {
              "Multiple": true,
              "MinItems": 1,
              "MaxItems": 10,
              "SearchDelay": 900,
              "MinCharacters": 2
            },
            "Lookup": {
              "AttributeNames": ["firstname", "lastname"],
              "AttributeFormat": "{0} {1}"
            }
          },
          {
            "CategoryId": "misc",
            "PathId": "invoice-to-detail",
            "AttributeName": "priceperunit",
            "Default": {
              "IsShown": true
            }
          },
          {
            "CategoryId": "misc",
            "PathId": "invoice-to-detail",
            "AttributeName": "priceperunit",
            "DisplayName": "Custom unit price"
          },
          {
            "CategoryId": "misc",
            "PathId": "invoice-to-product",
            "AttributeName": "name",
            "DisplayName": "Product name"
          }
        ],
        "ResultView": {
          "Columns": [
            {
              "Id": "invoice-name",
              "AttributeNames": ["name"],
              "DisplayName": "Name",
              "Width": "220"
            },
            {
              "AttributeNames": ["invoicenumber"]
            },
            {
              "Id": "invoice-created-by",
              "PathId": "invoice-created-by",
              "AttributeNames": ["fullname"]
            }
          ],
          "ShowAppliedFilters": true,
          "Pagination": {
            "List": [25, 50, 100],
            "AllOptionLabel": "All",
            "SummaryTemplate": "Showing {0} to {1} of {2} results"
          },
          "DefaultSort": [
            {
              "ColumnId": "invoice-created-by",
              "IsAscending": true
            },
            {
              "ColumnId": "invoice-name",
              "IsAscending": true
            }
          ]
        }
      },
      {
        "LogicalName": "account",
        "RelationPaths": [
          {
            "Id": "account-created-by",
            "Steps": [
              {
                "EntityName": "systemuser",
                "FromAttribute": "createdby",
                "ToAttribute": "systemuserid"
              }
            ]
          }
        ],
        "FilterCategories": [
          {
            "Id": "general",
            "DisplayName": "General"
          }
        ],
        "FilterOptions": [
          {
            "Id": "account-name-filter",
            "CategoryId": "general",
            "AttributeName": "name",
            "Default": {
              "IsShown": true
            },
            "Groupable": false
          },
          {
            "Id": "account-category-filter",
            "CategoryId": "general",
            "AttributeName": "accountcategorycode",
            "Default": {
              "IsShown": true,
              "Values": [1]
            },
            "Selection": {
              "Multiple": true
            }
          },
          {
            "CategoryId": "general",
            "AttributeName": "createdby",
            "Default": {
              "IsShown": true
            },
            "Lookup": {
              "AttributeNames": ["firstname", "lastname"],
              "AttributeFormat": "{0} {1}"
            },
            "Selection": {
              "Multiple": true,
              "MinItems": 1,
              "MaxItems": 2
            }
          }
        ],
        "DefaultFilterGroups": [
          {
            "FilterOptionIds": ["account-name-filter", "account-category-filter"],
            "Operator": "and",
            "GroupTitle": "Title of the group",
            "IsOperatorEditable": false,
            "IsRemovable": false
          }
        ],
        "ResultView": {
          "ShowAppliedFilters": true,
          "Columns": [
            {
              "AttributeNames": ["name", "accountnumber"],
              "AttributeFormat": "{0} ({1})",
              "DisplayName": "Account info"
            },
            {
              "PathId": "account-created-by",
              "AttributeNames": ["fullname"]
            }
          ],
          "Pagination": {
            "List": [25, 50, 100],
            "AllOptionLabel": "All",
            "SummaryTemplate": "Showing {0} to {1} of {2} results"
          }
        }
      }
    ],
    "Localization": {
      "FilterConditionLabels": {
        "eq": "Equal",
        "ne": "Not equal",
        "in": "In",
        "not-in": "Not in",
        "null": "Does not contain data",
        "not-null": "Contains data",
        "begins-with": "Begins with",
        "not-begin-with": "Does not begin with",
        "ends-with": "Ends with",
        "not-end-with": "Does not end with",
        "gt": "Greater than",
        "ge": "Greater than or equal",
        "lt": "Less than",
        "le": "Less than or equal",
        "today": "Today",
        "tomorrow": "Tomorrow",
        "yesterday": "Yesterday",
        "like": "Contains",
        "not-like": "Does not contain"
      }
    }
  }
}
